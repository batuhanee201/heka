# ── Uygulama ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# ── Supabase ──────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ── JWT ───────────────────────────────────────────────────────────
# En az 32 karakter, üretim ortamında rastgele üretilmeli
JWT_SECRET=change-me-at-least-32-chars-long!!
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── Argon2id ──────────────────────────────────────────────────────
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4

# ── CORS ──────────────────────────────────────────────────────────
# Birden fazla origin için virgülle ayır: https://app.com,https://admin.com
CORS_ORIGIN=*

# ── Rate Limiting ─────────────────────────────────────────────────
# Genel limit: 1 dakika içinde max istek sayısı
RATE_LIMIT_MAX=100
RATE_LIMIT_TIME_WINDOW=60000
